# ==============================================
# Environment Variables — Hotel Booking System
# Copy this file to .env and fill in the values
# ==============================================

# --- General ---
COMPOSE_PROJECT_NAME=hotel-booking
ENVIRONMENT=development

# --- Database Credentials (shared across all DBs) ---
DB_USER=admin
DB_PASSWORD=changeme

# --- Database Names (one per service) ---
AUTH_DB_NAME=auth_db
ROOM_DB_NAME=room_db
BOOKING_DB_NAME=booking_db
NOTIFICATION_DB_NAME=notification_db
PAYMENT_DB_NAME=payment_db

# --- Service Ports ---
FRONTEND_PORT=3000
GATEWAY_PORT=8080
AUTH_SERVICE_PORT=5001
ROOM_SERVICE_PORT=5002
BOOKING_SERVICE_PORT=5003
NOTIFICATION_SERVICE_PORT=5004
PAYMENT_SERVICE_PORT=5005

# --- Auth / Security ---
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
